<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.EV" parent="Theme.Material3.Dark.NoActionBar">
        <item name="android:windowBackground">#121212</item>
        <!-- Primary colors -->
        <item name="colorPrimary">@color/purple_200</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/black</item>

        <!-- Secondary colors -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>

        <!-- Surface colors (фоны) -->
        <item name="colorSurface">#121212</item>
        <item name="colorSurfaceVariant">#2D2D2D</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnSurfaceVariant">#B3B3B3</item>

        <!-- Error colors -->
        <item name="colorError">#CF6679</item>
        <item name="colorOnError">@color/black</item>

        <!-- Status bar -->
        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>